# Telegram: токен бота от @BotFather и id чата (узнать: node src/setup-telegram.mjs)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Телеграм-каналы читаются БЕЗ ключей (публичная веб-лента t.me/s/).
# Эти ключи нужны ТОЛЬКО чтобы развернуть папку-инвайт t.me/addlist/... в каналы
# (npm run tg:login + tg_fetch.py chatlist). my.telegram.org → API development tools.
TG_API_ID=
TG_API_HASH=
